DB_URL=postgresql://user:password@localhost:5432/linear_autopilot
BASE_URL=http://localhost:8080

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Session
JWT_SECRET=change-me-to-a-random-string
SESSION_TTL_MINUTES=60

# GitHub App
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY=your-github-app-private-key-pem
GITHUB_APP_SLUG=your-github-app-slug

# Linear OAuth
LINEAR_CLIENT_ID=your-linear-client-id
LINEAR_CLIENT_SECRET=your-linear-client-secret
LINEAR_REDIRECT_URL=http://localhost:8080/integrations/linear/callback

# Linear Webhook (configured in Linear app settings, not created programmatically)
LINEAR_WEBHOOK_SECRET=your-linear-webhook-signing-secret

# Claude / Sandbox
ANTHROPIC_API_KEY=your-anthropic-api-key
WORKER_IMAGE=linear-autopilot-worker:latest
SANDBOX_TTL=900

# Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG
